# EditorConfig helps keep formatting consistent across editors.
# https://editorconfig.org

root = true

[*]
indent_style = space
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# YAML: 2-space indent (IntelliJ style for flow brackets; YAML is in .prettierignore).
[*.{yml,yaml}]
indent_size = 2
